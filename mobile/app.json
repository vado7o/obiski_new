{
  "expo": {
    "name": "Obiski",
    "slug": "obiski",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f0eeff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.obiski.app"
    },
    "android": {
      "package": "com.obiski.app",
      "versionCode": 1,
      "compileSdkVersion": 35,
      "targetSdkVersion": 35,
      "minSdkVersion": 24,
      "adaptiveIcon": {
        "backgroundColor": "#f0eeff",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [],
    "extra": {
      "eas": {
        "projectId": "36403dce-1374-4640-a66b-50173b6015c7"
      }
    },
    "owner": "vado7os-team"
  }
}
